model Category {
 id String @id @default(cuid())
 name String @unique
 slug String @unique
 products Product[]
}
model Product {
 id String @id @default(cuid())
 name String
 slug String @unique
 price Decimal @db.Decimal(10, 2)
 stock Int @default(0)
 images String[]
 featured Boolean @default(false)
 categoryId String
 category Category @relation(fields: [categoryId], references: [id])
 orderItems OrderItem[]
}
model Order {
 id String @id @default(cuid())
 email String
 status OrderStatus @default(PENDING)
 total Decimal @db.Decimal(10, 2)
 items OrderItem[]
 stripeId String?
}
enum OrderStatus {
 PENDING 
 PAID 
 PROCESSING 
 SHIPPED 
 DELIVERED 
 CANCELLED
}
model OrderItem {
  id        String   @id @default(cuid())

  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])

  productId String
  product   Product  @relation(fields: [productId], references: [id])

  quantity  Int
}
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}